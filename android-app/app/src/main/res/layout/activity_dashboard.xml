<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_dashboard_header"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_logo_circle_light"
                android:padding="8dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:scaleType="fitCenter"
                    android:src="@drawable/barangay_logo" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/resident_portal"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#DDEEE0"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/textUnreadBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_badge"
                android:contentDescription="@string/notifications_badge_desc"
                android:minWidth="32dp"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingTop="6dp"
                android:paddingEnd="10dp"
                android:paddingBottom="6dp"
                android:text="0"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/buttonDashboardTab"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_nav_active"
                    android:backgroundTint="@null"
                    android:minWidth="0dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="@string/dashboard"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/buttonAnnouncementsTab"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_nav_inactive"
                    android:backgroundTint="@null"
                    android:minWidth="0dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="@string/announcements"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/buttonProfileTab"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_nav_inactive"
                    android:backgroundTint="@null"
                    android:minWidth="0dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:text="@string/profile"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_header_panel"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_overview"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="3dp"
                android:text="@string/dashboard_overview_subtitle"
                android:textColor="#E8F5E9"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="20dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_section_label"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:text="@string/dashboard_overview"
                android:textColor="@color/primary"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/border_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pending_requests_title"
                        android:textColor="@color/text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/pending_requests_subtitle"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:background="@color/divider" />

                    <TextView
                        android:id="@+id/textPendingRequests"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:lineSpacingExtra="4dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/border_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pending_complaints_title"
                        android:textColor="@color/text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/pending_complaints_subtitle"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:background="@color/divider" />

                    <TextView
                        android:id="@+id/textPendingComplaints"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:lineSpacingExtra="4dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_section_label"
                android:paddingStart="12dp"
                android:paddingTop="6dp"
                android:paddingEnd="12dp"
                android:paddingBottom="6dp"
                android:text="@string/dashboard_actions"
                android:textColor="@color/primary"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/dashboard_actions_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/border_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/request_document"
                        android:textColor="@color/primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="4dp"
                        android:text="@string/request_document_subtitle"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <Spinner
                        android:id="@+id/spinnerDocument"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_input_surface"
                        android:padding="12dp" />

                    <EditText
                        android:id="@+id/inputDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_input_surface"
                        android:focusable="false"
                        android:hint="Pickup Date"
                        android:padding="14dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/available_time_slots"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/buttonSlot1"
                                android:layout_width="wrap_content"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_slot_idle"
                                android:backgroundTint="@null"
                                android:minWidth="0dp"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:text="9AM-10AM"
                                android:textAllCaps="false"
                                android:textColor="@color/primary"
                                android:textSize="13sp"
                                android:gravity="center"
                                android:textStyle="bold" />

                            <Button
                                android:id="@+id/buttonSlot2"
                                android:layout_width="wrap_content"
                                android:layout_height="44dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_slot_idle"
                                android:backgroundTint="@null"
                                android:minWidth="0dp"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:text="10AM-11AM"
                                android:textAllCaps="false"
                                android:textColor="@color/primary"
                                android:textSize="13sp"
                                android:gravity="center"
                                android:textStyle="bold" />

                            <Button
                                android:id="@+id/buttonSlot3"
                                android:layout_width="wrap_content"
                                android:layout_height="44dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_slot_idle"
                                android:backgroundTint="@null"
                                android:minWidth="0dp"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:text="11AM-12NN"
                                android:textAllCaps="false"
                                android:textColor="@color/primary"
                                android:textSize="13sp"
                                android:gravity="center"
                                android:textStyle="bold" />

                            <Button
                                android:id="@+id/buttonSlot4"
                                android:layout_width="wrap_content"
                                android:layout_height="44dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_slot_idle"
                                android:backgroundTint="@null"
                                android:minWidth="0dp"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:text="1PM-2PM"
                                android:textAllCaps="false"
                                android:textColor="@color/primary"
                                android:textSize="13sp"
                                android:gravity="center"
                                android:textStyle="bold" />

                            <Button
                                android:id="@+id/buttonSlot5"
                                android:layout_width="wrap_content"
                                android:layout_height="44dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/bg_slot_idle"
                                android:backgroundTint="@null"
                                android:minWidth="0dp"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp"
                                android:text="2PM-3PM"
                                android:textAllCaps="false"
                                android:textColor="@color/primary"
                                android:textSize="13sp"
                                android:gravity="center"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </HorizontalScrollView>

                    <Button
                        android:id="@+id/buttonSubmitRequest"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_button_primary"
                        android:backgroundTint="@null"
                        android:text="Submit Request"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:gravity="center"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp"
                app:cardBackgroundColor="@color/surface_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/border_light"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/submit_complaint"
                        android:textColor="@color/primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="4dp"
                        android:text="@string/submit_complaint_subtitle"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <Spinner
                        android:id="@+id/spinnerCategory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_input_surface"
                        android:padding="12dp" />

                    <EditText
                        android:id="@+id/inputComplaintSubject"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_input_surface"
                        android:hint="Subject"
                        android:padding="14dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary" />

                    <EditText
                        android:id="@+id/inputComplaintDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_input_surface"
                        android:gravity="top"
                        android:hint="Description"
                        android:minLines="5"
                        android:padding="14dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary" />

                    <Button
                        android:id="@+id/buttonSubmitComplaint"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_button_primary"
                        android:backgroundTint="@null"
                        android:text="Submit Complaint"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:gravity="center"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
